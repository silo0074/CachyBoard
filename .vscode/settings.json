{
	"files.exclude": {
        "**/.git": false
    },

	"editor.matchBrackets": "always",
    "editor.guides.bracketPairs": false,
    "editor.guides.bracketPairsHorizontal": false,
    "[cpp]": {
        "editor.bracketPairColorization.enabled": true
    },

	"workbench.colorCustomizations": {
		"editorBracketMatch.background": "#00ff15", // Solid Red Background
		"editorBracketMatch.border": "#ffffff",     // White Border
		// "editorBracketHighlight.foreground1": "#ffd700", // Force colorization color 1
		"editorBracketHighlight.unexpectedBracket.foreground": "#ff0000"
	},

    "files.associations": {
        "CMakeLists.txt": "cmake"
    },

    "cSpell.ignorePaths": [
		"**/*settings.json",
        "**/*.desktop",          // any file with the .desktop extension
        "**/CMakeLists.txt"      // the CMakeLists file at any folder depth
    ],

    "cSpell.words": [
        "Bksp",
        "CAPSLOCK",
        "EVBIT",
        "keysym",
        "LEFTCTRL",
        "libx",
        "libxkbcommon",
        "libxtst",
        "pacman",
        "ZXCV"
    ]
}