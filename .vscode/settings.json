{
	"files.exclude": {
        "**/.git": false
    },

    "files.associations": {
        "CMakeLists.txt": "cmake"
    },

    "cSpell.ignorePaths": [
		"**/*settings.json",
        "**/*.desktop",          // any file with the .desktop extension
        "**/CMakeLists.txt"      // the CMakeLists file at any folder depth
    ],

    "cSpell.words": [
		"Bksp",
		"cachyboard",
		"CAPSL",
		"CAPSLOCK",
		"EVBIT",
		"EVIOCGKEY",
		"EVIOCGLED",
		"keysym",
		"LEFTCTRL",
		"libx",
		"libxkbcommon",
		"libxtst",
		"pacman",
		"qlineargradient",
		"qputenv",
		"qresource",
		"RIGHTCTRL",
		"udevadm",
		"uinput",
		"unpolish",
		"usermod",
		"VIRTUALKEYBOARD",
		"ZXCV"
	]
}