# Ubuntu Noble (24.04)
FROM ubuntu:noble

ENV DEBIAN_FRONTEND=noninteractive

# Added libxkbcommon-dev and liblayershellqtinterface-dev
# Replaced qt6-multimedia-dev with libcanberra-dev
RUN apt-get update && apt-get install -y \
    build-essential \
    cmake \
    git \
    file \
    pkg-config \
    dpkg-dev \
    qt6-base-dev \
    libcanberra-dev \
    liblayershellqtinterface-dev \
    libxkbcommon-dev \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /project
